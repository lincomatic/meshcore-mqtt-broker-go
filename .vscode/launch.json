{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Launch Broker",
            "type": "go",
            "request": "launch",
            "mode": "debug",
            "program": "${workspaceFolder}/cmd/broker",
            "envFile": "${workspaceFolder}/.env",
            "cwd": "${workspaceFolder}",
            "stopOnEntry": false,
            "args": []
        },
        {
            "name": "Launch Broker (Race Detector)",
            "type": "go",
            "request": "launch",
            "mode": "debug",
            "program": "${workspaceFolder}/cmd/broker",
            "envFile": "${workspaceFolder}/.env",
            "cwd": "${workspaceFolder}",
            "stopOnEntry": false,
            "buildFlags": "-race",
            "args": []
        },
        {
            "name": "Test Current Package",
            "type": "go",
            "request": "launch",
            "mode": "test",
            "program": "${fileDirname}",
            "envFile": "${workspaceFolder}/.env",
            "args": ["-v"]
        }
    ]
}
